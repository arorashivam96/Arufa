# Azure OpenAI configuration
AOAI_ENDPOINT=https://arufa-aoai-shivamarora.openai.azure.com/
AOAI_API_VERSION=2024-10-21

# Deployments (name of the deployment on the AOAI resource)
AOAI_DEPLOYMENT_NANO=gpt-5-nano
AOAI_DEPLOYMENT_MINI=gpt-5-mini

# Values written to the X-Model-Name response header
AOAI_MODEL_NAME_NANO=gpt-5-nano
AOAI_MODEL_NAME_MINI=gpt-5-mini

# Auth mode: key (local dev) or aad (cloud, managed identity)
AOAI_AUTH_MODE=key
AOAI_API_KEY=

# Reliability knobs (kept below the platform's 60 s per-call ceiling)
LLM_TIMEOUT_S=25
LLM_MAX_CONCURRENCY=20
LLM_MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO
